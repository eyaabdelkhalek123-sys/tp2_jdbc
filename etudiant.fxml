<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="ma.projet.controller.ControllerEtudiant">

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Gestion des etudiants">
      <font>
         <Font name="System Italic" size="24.0" />
      </font></Label>

    <GridPane hgap="10" vgap="10">
        <Label text="Nom :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="tfNom" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Prenom :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="tfPrenom" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Sexe :" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <ComboBox fx:id="cbSexe" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Filiere :" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="tfFiliere" GridPane.columnIndex="1" GridPane.rowIndex="3" />
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox spacing="10">
        <Button onAction="#ajouterEtudiant" text="Ajouter" textFill="#a2d92b">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Button>
        <Button onAction="#modifierEtudiant" text="Modifier" textFill="#24ccbb">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Button>
        <Button onAction="#supprimerEtudiant" text="Supprimer" textFill="#ff0051">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Button>
        <Button onAction="#chargerTous" text="Rafraîchir" textFill="#796dff">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Button>
    </HBox>

    <TableView fx:id="tableEtudiants" prefHeight="300">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50" text="ID" />
            <TableColumn fx:id="colNom" prefWidth="120" text="Nom" />
            <TableColumn fx:id="colPrenom" prefWidth="120" text="Prénom" />
            <TableColumn fx:id="colSexe" prefWidth="60" text="Sexe" />
            <TableColumn fx:id="colFiliere" prefWidth="120" text="Filière" />
        </columns>
    </TableView>

    <Label fx:id="lblMessage" style="-fx-text-fill: green;" />
</VBox>
